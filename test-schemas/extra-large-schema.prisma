enum BillingStatus {
  // files that will be billed e.g. finalized files or files reprocessed after they have been billed
  // for every reprocessed billed file, there will be a finalised previously billed file
  BILLED
  // files that will not be billed e.g. failed, replaced, ignored, invalidated, pending review files
  UNBILLED
  // files that have been previously billed e.g. the reprocessed files for finalised files that were already billed
  // for every finalised previously billed file, there will be a reprocessed billed file saved in the previously_billed_metadata_id column
  PREVIOUSLY_BILLED
}

// This status is different from the ProcessingStatus because it indicates whether or not the IPM
// has been inserted into the finalized or tombstone table
enum FinalizationStatus {
  // the file has neither been finalized nor tombstoned
  UNFINALIZED
  // the file is in the process of being finalized
  FINALIZING
  // the file has been finalized
  FINALIZED
  // the file is in the process of being tombstoned
  TOMBSTONING
  // the file has been tombstoned
  TOMBSTONED
}

