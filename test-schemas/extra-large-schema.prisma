  provisionallyCalculatedFilename String?            @map("provisionally_calculated_filename")
  billedFilename                  String?            @map("billed_filename")
  billingDate                     DateTime?          @map("billing_date")
  totalImpressions                BigInt?            @map("total_impressions")

