  // e.g. TTD ~ scope3: user/password, user: no auth
  authenticationTokenType             ActivationPlatformAuthenticationToken  @map("authentication_token_type") // How scope3 gives auth creds
  userAuthenticationTokenType         ActivationPlatformAuthenticationToken  @map("user_authentication_token_type") // How the user gives auth creds
